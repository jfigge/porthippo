# Port Hippo integration-test sandbox configuration.
# Read automatically by docker compose AND by access.sh. Throwaway creds — this
# rig is for LOCAL TESTING ONLY, never expose it.
COMPOSE_PROJECT_NAME=porthippo-sandbox

# SSH login used on BOTH containers (password + the generated key both work).
SSH_USER=tunnel
SSH_PASSWORD=tunnelpass

# ── Networks (static addressing) ─────────────────────────────────────────────
# front: host-reachable; only the jump host is attached.
FRONT_SUBNET=172.28.0.0/24
JUMP_FRONT_IP=172.28.0.11
# back: internal-only (no host/internet route); jump ↔ dest live here.
BACK_SUBNET=172.29.0.0/24
JUMP_BACK_IP=172.29.0.11
DEST_BACK_IP=172.29.0.12

# Host port that forwards to the jump host's sshd (127.0.0.1 on this machine).
JUMP_SSH_PORT=2201

# Loopback-only echo port inside each container (reachable ONLY via an SSH forward).
ECHO_PORT=7000

# Network-facing echo port inside each container (bound to 0.0.0.0). Unlike the
# loopback echo, this is reachable across the container network — so the SEALED
# `dest` is reachable from `jump` at ${DEST_BACK_IP}:${NET_ECHO_PORT}. This is what
# a DYNAMIC (SOCKS) tunnel exiting at the jump reaches to prove it can hit a host
# sealed behind the bastion. It is NOT published to the host.
NET_ECHO_PORT=7001

# ── New-tunnel-type test parameters (Feature 110) ────────────────────────────
# DYNAMIC: the local SOCKS5 port Port Hippo binds (exits at the jump host).
SOCKS_LOCAL_PORT=18080
# REMOTE: the port the reverse tunnel binds ON the jump host (loopback), and the
# host-side echo it forwards back to (run it with `make sandbox-host-echo`).
REMOTE_BIND_PORT=9090
HOST_ECHO_PORT=9091
