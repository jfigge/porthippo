{
  "name": "jumphippo",
  "version": "0.9.0",
  "description": "On-demand SSH tunnel manager",
  "homepage": "https://github.com/jfigge/jumphippo",
  "repository": {
    "type": "git",
    "url": "https://github.com/jfigge/jumphippo.git"
  },
  "author": {
    "name": "Jason Figge",
    "email": "jason.figge@gmail.com"
  },
  "license": "Apache-2.0",
  "main": "app/main.js",
  "scripts": {
    "start": "electron app/main.js",
    "dev": "electron app/main.js --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "fmt": "prettier --write \"web/**/*.{js,css,html}\" \"app/**/*.js\"",
    "lint": "eslint \"web/scripts/**/*.js\" \"app/**/*.js\"",
    "test": "node --test app/tests/",
    "vendor-markdown": "esbuild web/scripts/vendor/markdown-entry.js --bundle --format=esm --outfile=web/scripts/vendor/markdown.js",
    "vendor-terminal": "esbuild web/scripts/vendor/terminal-entry.js --bundle --format=esm --outfile=web/scripts/vendor/xterm.js && cp node_modules/@xterm/xterm/css/xterm.css web/scripts/vendor/xterm.css"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.7",
    "electron": "^43.1.1",
    "electron-builder": "~26.15.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jsdom": "^27.0.1",
    "marked": "^18.0.4",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ssh2": "^1.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.jumphippo.app",
    "productName": "Jump Hippo",
    "copyright": "Copyright © 2026 Jason Figge",
    "artifactName": "Jump-Hippo-${version}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "jfigge",
      "repo": "jumphippo"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "web/**/*",
      "package.json",
      "REVISION_INFO.txt",
      "!**/node_modules/ssh2/lib/protocol/crypto/build/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "web/jumphippo-mac-icon.png",
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Jump Hippo needs local network access to open SSH tunnels to hosts on your local network, such as a jump host or destination at a 10.x, 172.16–31.x or 192.168.x address."
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "packaging/entitlements.mac.plist",
      "entitlementsInherit": "packaging/entitlements.mac.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "mas": {
      "type": "distribution",
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Jump Hippo needs local network access to open SSH tunnels to hosts on your local network, such as a jump host or destination at a 10.x, 172.16–31.x or 192.168.x address."
      },
      "category": "public.app-category.developer-tools",
      "icon": "web/jumphippo-mac-icon.png",
      "notarize": false,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "packaging/entitlements.mas.plist",
      "entitlementsInherit": "packaging/entitlements.mas.inherit.plist",
      "provisioningProfile": "packaging/embedded.provisionprofile",
      "target": [
        {
          "target": "pkg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "masDev": {
      "type": "development",
      "notarize": false,
      "entitlements": "packaging/entitlements.mas.plist",
      "entitlementsInherit": "packaging/entitlements.mas.inherit.plist",
      "provisioningProfile": "packaging/development.provisionprofile"
    },
    "appx": {
      "identityName": "FILL-LATER-PartnerCenter-IdentityName",
      "publisher": "CN=FILL-LATER-PartnerCenter-Publisher",
      "publisherDisplayName": "Jason Figge",
      "applicationId": "JumpHippo",
      "backgroundColor": "#1c1c1c",
      "showNameOnTiles": true,
      "languages": [
        "en-US",
        "de-DE",
        "es-ES",
        "fr-FR",
        "it-IT",
        "ja-JP",
        "zh-CN"
      ]
    },
    "win": {
      "icon": "web/icons/256x256.png",
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      },
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Jump-Hippo-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "category": "Network",
      "icon": "web/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
