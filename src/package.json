{
  "name": "porthippo",
  "version": "0.1.0",
  "description": "On-demand SSH tunnel manager",
  "homepage": "https://github.com/jfigge/porthippo",
  "repository": {
    "type": "git",
    "url": "https://github.com/jfigge/porthippo.git"
  },
  "author": {
    "name": "Jason Figge",
    "email": "jason.figge@gmail.com"
  },
  "license": "Apache-2.0",
  "main": "app/main.js",
  "scripts": {
    "start": "electron app/main.js",
    "dev": "electron app/main.js --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "fmt": "prettier --write \"web/**/*.{js,css,html}\" \"app/**/*.js\"",
    "lint": "eslint \"web/scripts/**/*.js\" \"app/**/*.js\"",
    "test": "node --test app/tests/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "electron": "^42.1.0",
    "electron-builder": "~26.8.1",
    "eslint": "^9.39.4",
    "globals": "^16.1.0",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ssh2": "^1.16.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.porthippo.app",
    "productName": "Port Hippo",
    "copyright": "Copyright © 2026 Jason Figge",
    "artifactName": "Port-Hippo-${version}-${arch}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "jfigge",
      "repo": "porthippo"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "web/**/*",
      "package.json",
      "REVISION_INFO.txt"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "web/icons/1024x1024.png",
      "extendInfo": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "packaging/entitlements.mac.plist",
      "entitlementsInherit": "packaging/entitlements.mac.plist",
      "notarize": true,
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "icon": "web/icons/256x256.png",
      "signtoolOptions": {
        "signingHashAlgorithms": ["sha256"],
        "rfc3161TimeStampServer": "http://timestamp.digicert.com"
      },
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "nsis": {
      "artifactName": "Port-Hippo-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "category": "Network",
      "icon": "web/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "deb",
          "arch": ["x64", "arm64"]
        }
      ]
    }
  }
}
